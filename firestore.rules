rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isOwner(recordId) {
      return isSignedIn() && get(/databases/$(database)/documents/serviceRecords/$(recordId)).data.userId == request.auth.uid;
    }

    function isValidServiceRecord(data) {
      return data.userId == request.auth.uid && 
             data.keys().hasAll(['userId', 'createdAt', 'updatedAt']);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['actionName', 'createdAt']) && 
             data.actionName is string && data.actionName.size() <= 200;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'createdAt']) && data.amount is number;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'createdAt']) && 
             data.url is string && data.url.size() <= 1048576; // 1MB limit for base64
    }

    match /serviceRecords/{recordId} {
      allow get: if true;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && isValidServiceRecord(incoming());
      allow update: if (isSignedIn() && isValidId(recordId) && isValidServiceRecord(incoming()) && incoming().userId == existing().userId) ||
                    (incoming().diff(existing()).affectedKeys().hasOnly(['customerSignature', 'updatedAt']) && incoming().customerSignature is string);
      allow delete: if isOwner(recordId);
      
      match /logs/{logId} {
        allow read: if isOwner(recordId);
        allow create: if isValidId(logId) && isValidLog(incoming()) && (
          isOwner(recordId) || incoming().actionName == 'Dijital İmza Onayı'
        );
        allow update: if false;
        allow delete: if isOwner(recordId);
      }

      match /transactions/{txId} {
        allow read: if isOwner(recordId);
        allow create: if isOwner(recordId) && isValidId(txId) && isValidTransaction(incoming());
        allow update: if false;
        allow delete: if isOwner(recordId);
      }

      match /photos/{photoId} {
        allow read: if isOwner(recordId);
        allow create: if isOwner(recordId) && isValidId(photoId) && isValidPhoto(incoming());
        allow delete: if isOwner(recordId);
      }
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isOwner(recordId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/serviceRecords/$(recordId)) &&
             get(/databases/$(database)/documents/serviceRecords/$(recordId)).data.userId == request.auth.uid;
    }

    function isValidServiceRecord(data) {
      return data.userId == request.auth.uid && 
             data.keys().hasAll(['userId', 'createdAt', 'updatedAt']);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['actionName', 'createdAt']) && 
             data.actionName is string && data.actionName.size() <= 200;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'createdAt']) && data.amount is number;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'createdAt']) && 
             data.url is string && data.url.size() <= 1048576; // 1MB limit for base64
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && (existing().role == incoming().role);
      allow delete: if false;
    }
    
    match /accountingRecords/{recordId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && 
                    incoming().keys().hasAll(['userId', 'type', 'amount', 'description', 'createdAt']) &&
                    incoming().userId == request.auth.uid &&
                    incoming().type is string &&
                    incoming().amount is number &&
                    incoming().description is string;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow update: if false;
    }
    
    match /stockRecords/{recordId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    
    match /stockMovements/{recordId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
    
    match /serviceRecords/{recordId} {
      allow get: if true;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(recordId) && isValidServiceRecord(incoming());
      allow update: if (isSignedIn() && isValidId(recordId) && isValidServiceRecord(incoming()) && incoming().userId == existing().userId) ||
                    (incoming().diff(existing()).affectedKeys().hasOnly(['customerSignature', 'updatedAt']) && incoming().customerSignature is string);
      allow delete: if isOwner(recordId);
      
      match /logs/{logId} {
        allow read: if isOwner(recordId);
        allow create: if isValidId(logId) && isValidLog(incoming()) && (
          isOwner(recordId) || incoming().actionName == 'Dijital İmza Onayı'
        );
        allow update: if false;
        allow delete: if isOwner(recordId);
      }

      match /transactions/{txId} {
        allow read: if isOwner(recordId);
        allow create: if isOwner(recordId) && isValidId(txId) && isValidTransaction(incoming());
        allow update: if false;
        allow delete: if isOwner(recordId);
      }

      match /photos/{photoId} {
        allow read: if isOwner(recordId);
        allow create: if isOwner(recordId) && isValidId(photoId) && isValidPhoto(incoming());
        allow delete: if isOwner(recordId);
      }

      match /pdfHistory/{pdfLogId} {
        allow read, list: if isOwner(recordId);
        allow create: if isOwner(recordId) && isValidId(pdfLogId);
        allow update: if isOwner(recordId);
        allow delete: if false;
      }
    }
  }
}
